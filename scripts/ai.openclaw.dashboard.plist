<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ai.openclaw.dashboard.plist — Bloque 3 FASE 8

  LaunchAgent that auto-starts the Next.js dashboard + WS subscriber
  on login. Runs under the current user, not root.

  Install:
    cp scripts/ai.openclaw.dashboard.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/ai.openclaw.dashboard.plist

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/ai.openclaw.dashboard.plist
    rm ~/Library/LaunchAgents/ai.openclaw.dashboard.plist

  Logs:
    tail -f /tmp/openclaw-dashboard.log
    tail -f /tmp/openclaw-subscriber.log
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw.dashboard</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>cd ~/openclawsetup/dashboard &amp;&amp; /opt/homebrew/bin/npm run dev -- --port 3000 2&gt;&amp;1 | tee /tmp/openclaw-dashboard.log</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/openclaw-dashboard.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/openclaw-dashboard.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>NODE_ENV</key>
    <string>development</string>
  </dict>
</dict>
</plist>
